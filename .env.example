SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_DB_PASSWORD=your_supabase_db_password_here
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
NVIDIA_EMBEDDING_MODEL=nvidia/nv-embed-v1
NVIDIA_MAX_TOKENS=1024
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.95
APP_ENV=development
DISASTERMIND_API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
MAX_REQUEST_BYTES=65536
ENABLE_BACKEND_KEEPALIVE=true
BACKEND_KEEPALIVE_URL=https://your-render-backend.onrender.com
BACKEND_KEEPALIVE_INTERVAL_SECONDS=300
ENABLE_SUPABASE_KEEPALIVE=true
SUPABASE_KEEPALIVE_INTERVAL_SECONDS=86400
